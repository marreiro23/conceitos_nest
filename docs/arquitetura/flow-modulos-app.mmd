flowchart TB
  subgraph Core
    AppModule[AppModule]
  end

  subgraph Domain
    RecadosModule[RecadosModule]
    PessoasModule[PessoasModule]
    ConceitosAutomaticoModule[ConceitosAutomaticoModule]
    ConceitosManualModule[ConceitosManualModule]
  end

  subgraph Infra
    ConfigModule[ConfigModule.forRoot global env .env.local/.env]
    TypeOrmRoot[TypeOrmModule.forRoot postgres autoLoadEntities synchronize migrationsRun]
    RecadoFeature[TypeOrmModule.forFeature Recado]
    PessoaFeature[TypeOrmModule.forFeature Pessoa]
    DynamicRecados[MyDynamicModule.register Recados]
    DynamicPessoas[MyDynamicModule.register Pessoas]
  end

  AppModule --> ConfigModule
  AppModule --> TypeOrmRoot
  AppModule --> RecadosModule
  AppModule --> PessoasModule

  RecadosModule --> PessoasModule
  RecadosModule --> RecadoFeature
  RecadosModule --> DynamicRecados
  PessoasModule --> PessoaFeature
  PessoasModule --> DynamicPessoas

  RecadosModule -. forwardRef para evitar ciclo .-> PessoasModule

  ConceitosAutomaticoModule -. nao importado no AppModule .-> AppModule
  ConceitosManualModule -. nao importado no AppModule .-> AppModule
