@baseUrl = http://localhost:3000

# PESSOAS
### Criar uma pessoa
POST {{baseUrl}}/pessoas
Content-Type: application/json

{
  "nome": "Joana Dark",
  "email": "joana.dark@example.com",
  "passwordHash": "hashed_password_123"
}

### Listar todas as pessoas
GET {{baseUrl}}/pessoas

### Buscar uma pessoa por ID
GET {{baseUrl}}/pessoas/19

### Atualizar uma pessoa
PATCH {{baseUrl}}/pessoas/19
Content-Type: application/json

{
  "nome": "Joana Dark Atualizada",
  "email": "joana.dark.atualizada@example.com"
}

### Deletar uma pessoa
DELETE {{baseUrl}}/pessoas/19

### Deletar todas as pessoas
DELETE {{baseUrl}}/pessoas/


# RECADOS
### RecadosController

# @name RecadosController

### lista todos os recados
GET {{baseUrl}}/recados/
?limit=10
&offset=0
Authorization: Bearer 123456

### lista apenas um recado
GET {{baseUrl}}/recados/76/

### cria um recado
POST {{baseUrl}}/recados/
Content-Type: application/json

{
"deId": 18,
"paraId": 20,
"texto": "deId 18 'Joana' paraId 20'Leo'"
  }

### cria um recado (texto automático no backend)
POST {{baseUrl}}/recados/
Content-Type: application/json

{
"texto": "Recado automático",
"deId": 20,
"paraId": 18
}


### atualiza um recado
PATCH {{baseUrl}}/recados/36/
Content-Type: application/json

{
    "texto": "De Joanajkgb para Leo: Recado atualizado",
    "lido": true
}

### Apaga um recado
DELETE {{baseUrl}}/recados/-7/


### Apaga todos os recados
DELETE {{baseUrl}}/recados/



